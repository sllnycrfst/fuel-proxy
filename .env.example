# ─── Required env vars (set in Render dashboard) ──────────────────────

# NSW FuelCheck API credentials.
# Get these from https://api.nsw.gov.au/ — they're free to register.
# The merged service accepts EITHER variable-name style. The existing
# nsw-proxy Render env vars are named without the underscore between
# API and KEY/SECRET, so those work as-is on this combined service too.
NSW_APIKEY=your_nsw_api_key_here
NSW_APISECRET=your_nsw_api_secret_here
# Alternative names also accepted:
# NSW_API_KEY=
# NSW_API_SECRET=

# Optional — pre-built Basic auth header (overrides NSW_API_KEY+SECRET
# if set; mostly for debugging or testing without exposing the secret).
# NSW_BASIC_AUTH=Basic ...

# Token required to hit the NSW admin /nsw/refresh endpoint.
# Pick something random — it doesn't unlock anything more dangerous than
# forcing a full NSW refresh (which still respects the API quota).
REFRESH_TOKEN=change-me-to-something-random

# ─── Optional ─────────────────────────────────────────────────────────

# QLD API token. Defaults to the existing prod token if not set, so this
# is only needed if rotating it.
# QLD_TOKEN=

# Apple MapKit JS token (used by sellanycarfast.com.au /mapkit-token).
# Leave unset if not using that integration.
# MAPKIT_TOKEN=

# Server port. Render injects this automatically; only set for local dev.
# PORT=3000
